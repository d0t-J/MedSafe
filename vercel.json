{
    "version": 2,
    "builds": [
        {
            "src": "api/index.py",
            "use": "@vercel/python"
        },
        {
            "src": "static/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/index.py"
        },
        {
            "src": "/",
            "dest": "/static/index.html"
        },
        {
            "src": "/login",
            "dest": "/static/login.html"
        },
        {
            "src": "/profile",
            "dest": "/static/profile.html"
        },
        {
            "src": "/static/(.*)",
            "dest": "/static/$1"
        }
    ]
}
